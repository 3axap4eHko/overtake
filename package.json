{
  "name": "overtake",
  "version": "2.0.0",
  "description": "NodeJS performance benchmark",
  "type": "module",
  "types": "build/index.d.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "import": "./src/index.ts"
  },
  "bin": {
    "overtake": "bin/overtake.js"
  },
  "scripts": {
    "build": "rm -rf build && tsc --declaration --emitDeclarationOnly",
    "start": "./bin/overtake.js",
    "test": "node --experimental-test-module-mocks --test src/__tests__/*.ts",
    "test:cov": "node --experimental-test-module-mocks --experimental-test-coverage --test src/__tests__/*.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3axap4eHko/overtake.git"
  },
  "keywords": [
    "benchmark",
    "performance",
    "measure",
    "worker"
  ],
  "author": "Ivan Zakharchanka",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/3axap4eHko/overtake/issues"
  },
  "homepage": "https://github.com/3axap4eHko/overtake#readme",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/progress": "^2.0.7",
    "husky": "^9.1.7",
    "overtake": "^1.3.1",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@swc/core": "^1.15.18",
    "progress": "^2.0.3"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
